{
  "compilerOptions": {

    "module": "CommonJS",
    "target": "esnext",
    "types": [],
    // For nodejs:
    "lib": ["DOM", "ESNext"],
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  }
}
